PORT=3000

# Supabase server-side database connection.
# Use the Project URL and the service_role/secret key. Never put this key in frontend apps.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

